// Debate Tournament Management API — data model
// British Parliamentary (BP) format: 4 teams per room (OG, OO, CG, CO),
// each round ranks teams 1st-4th, which maps to 3/2/1/0 team points.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ADJUDICATOR
  DEBATER
}

enum BPPosition {
  OG // Opening Government
  OO // Opening Opposition
  CG // Closing Government
  CO // Closing Opposition
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(DEBATER)
  createdAt    DateTime @default(now())

  adjudicatorRounds RoundAdjudicator[]
  debater           Debater?
}

model Tournament {
  id          String   @id @default(uuid())
  name        String
  location    String?
  startDate   DateTime
  endDate     DateTime
  breakSize   Int      @default(8) // number of teams that advance to elimination rounds
  createdAt   DateTime @default(now())

  teams  Team[]
  rounds Round[]
}

model Team {
  id           String   @id @default(uuid())
  name         String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String

  debaters     Debater[]
  assignments  RoundTeam[]

  @@unique([tournamentId, name])
}

model Debater {
  id     String  @id @default(uuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])
  name   String

  team   Team?   @relation(fields: [teamId], references: [id])
  teamId String?
}

model Motion {
  id        String  @id @default(uuid())
  text      String
  infoSlide String?

  round Round?
}

model Round {
  id           String     @id @default(uuid())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId String
  roundNumber  Int
  isElimination Boolean   @default(false)

  motion   Motion? @relation(fields: [motionId], references: [id])
  motionId String? @unique

  teams        RoundTeam[]
  adjudicators RoundAdjudicator[]

  @@unique([tournamentId, roundNumber])
}

// A team's position and result within a specific round.
model RoundTeam {
  id       String     @id @default(uuid())
  round    Round      @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId  String
  team     Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   String
  position BPPosition

  rank        Int? // 1-4, set once ballots are submitted
  speakerPts  Int? // sum of speaker scores for the team in this round
  teamPoints  Int? // derived: 3/2/1/0 based on rank

  @@unique([roundId, teamId])
  @@unique([roundId, position])
}

model RoundAdjudicator {
  id       String @id @default(uuid())
  round    Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId  String
  user     User   @relation(fields: [userId], references: [id])
  userId   String
  isChair  Boolean @default(false)

  @@unique([roundId, userId])
}
